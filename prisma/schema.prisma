generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  PAINTING
  READY
  DELIVERED
}

model Workshop {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  address   String?

  admins    Admin[]
  customers Customer[]
  orders    Order[]

  createdAt DateTime @default(now())
}

model Admin {
  id           String   @id @default(uuid())
  workshopId   String

  name         String
  email        String   @unique
  passwordHash String

  role         String   @default("ADMIN")
  isActive     Boolean  @default(true)

  workshop     Workshop @relation(fields: [workshopId], references: [id])

  orders       Order[]
  statusLogs   StatusLog[]

  createdAt    DateTime @default(now())
}

model Customer {
  id          String   @id @default(uuid())
  workshopId  String

  name        String
  phone       String
  address     String?

  workshop    Workshop @relation(fields: [workshopId], references: [id])

  orders      Order[]

  createdAt   DateTime @default(now())
}

model Order {
  id                 String        @id @default(uuid())

  workshopId         String
  customerId         String
  adminId            String

  billNo             String        @unique

  totalPrice         Decimal       @db.Decimal(10, 2)
  advancePaid        Decimal       @db.Decimal(10, 2)

  status             OrderStatus   @default(PENDING)

  notes              String?

  expectedDelivery   DateTime?

  workshop           Workshop      @relation(fields: [workshopId], references: [id])
  customer           Customer      @relation(fields: [customerId], references: [id])
  admin              Admin         @relation(fields: [adminId], references: [id])

  murtiItems         MurtiItem[]
  statusLogs         StatusLog[]

  createdAt          DateTime      @default(now())
}

model MurtiItem {
  id                   String   @id @default(uuid())

  orderId              String

  murtiName            String
  murtiType            String?

  heightInches         Float?

  clayType             String?

  specialInstructions  String?

  order                Order @relation(fields: [orderId], references: [id])

  createdAt            DateTime @default(now())
}

model StatusLog {
  id             String      @id @default(uuid())

  orderId        String
  adminId        String

  oldStatus      OrderStatus
  newStatus      OrderStatus

  notes          String?

  order          Order       @relation(fields: [orderId], references: [id])
  admin          Admin       @relation(fields: [adminId], references: [id])

  changedAt      DateTime @default(now())
}