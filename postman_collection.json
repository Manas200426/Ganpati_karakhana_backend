{
  "info": {
    "name": "Ganpati Karkhana API",
    "description": "Full API collection for the Ganpati Management backend. Run requests top-to-bottom within a folder — chained requests (login, create customer, create order, upload photo) auto-save IDs/tokens into collection variables via test scripts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "b6f2a2e0-1a1a-4a1a-9a1a-ganpati0001"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "adminId", "value": "", "type": "string" },
    { "key": "workshopId", "value": "", "type": "string", "description": "Auto-filled by Workshops > Create Workshop. Alternatively use the seeded workshop from prisma/seed.js." },
    { "key": "customerId", "value": "", "type": "string" },
    { "key": "orderId", "value": "", "type": "string" },
    { "key": "murtiItemId", "value": "", "type": "string" },
    { "key": "photoId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Root",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] }
          }
        },
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "Workshops",
      "item": [
        {
          "name": "Create Workshop",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"DeepKala Mandir\",\n  \"phone\": \"9999999999\",\n  \"whatsappNumber\": \"9324273637\",\n  \"address\": \"Pune\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/workshops", "host": ["{{baseUrl}}"], "path": ["api", "workshops"] },
            "description": "Public endpoint — no auth required, since a workshop must exist before its first admin can register."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set(\"workshopId\", res.data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Workshop By Id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/workshops/{{workshopId}}", "host": ["{{baseUrl}}"], "path": ["api", "workshops", "{{workshopId}}"] },
            "description": "Requires auth. Only returns the workshop if it matches the logged-in admin's own workshopId."
          }
        },
        {
          "name": "Update Workshop",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"DeepKala Mandir Updated\",\n  \"phone\": \"9999999998\",\n  \"address\": \"Shukrawar Peth, Pune\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/workshops/{{workshopId}}", "host": ["{{baseUrl}}"], "path": ["api", "workshops", "{{workshopId}}"] }
          }
        },
        {
          "name": "Delete Workshop",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/workshops/{{workshopId}}", "host": ["{{baseUrl}}"], "path": ["api", "workshops", "{{workshopId}}"] },
            "description": "DANGER: cascades and deletes every admin, customer, order, murtiItem and photo under this workshop, then the workshop itself. Run this last."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Admin",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Hemansh\",\n  \"email\": \"admin2@test.com\",\n  \"password\": \"123456\",\n  \"workshopId\": \"{{workshopId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set(\"token\", res.data.token);",
                  "  pm.collectionVariables.set(\"adminId\", res.data.admin.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Admin",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set(\"token\", res.data.token);",
                  "  pm.collectionVariables.set(\"adminId\", res.data.admin.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current Admin",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ramesh Kulkarni\",\n  \"phone\": \"9876543210\",\n  \"address\": \"Shukrawar Peth, Pune\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/customers", "host": ["{{baseUrl}}"], "path": ["api", "customers"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set(\"customerId\", res.data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Customers",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/customers", "host": ["{{baseUrl}}"], "path": ["api", "customers"] }
          }
        },
        {
          "name": "Get Customer By Id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/customers/{{customerId}}", "host": ["{{baseUrl}}"], "path": ["api", "customers", "{{customerId}}"] }
          }
        },
        {
          "name": "Update Customer",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ramesh Kulkarni Updated\",\n  \"address\": \"Narayan Peth, Pune\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/customers/{{customerId}}", "host": ["{{baseUrl}}"], "path": ["api", "customers", "{{customerId}}"] }
          }
        },
        {
          "name": "Delete Customer",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/customers/{{customerId}}", "host": ["{{baseUrl}}"], "path": ["api", "customers", "{{customerId}}"] }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"billNo\": \"BILL-1001\",\n  \"totalPrice\": 15000,\n  \"advancePaid\": 5000,\n  \"notes\": \"Handle with care\",\n  \"expectedDelivery\": \"2026-08-20\",\n  \"murtiItems\": [\n    {\n      \"murtiName\": \"Ganpati Bappa\",\n      \"murtiType\": \"Traditional\",\n      \"heightInches\": 18,\n      \"clayType\": \"Shadu\",\n      \"specialInstructions\": \"Golden crown\"\n    }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set(\"orderId\", res.data.id);",
                  "  if (res.data.murtiItems && res.data.murtiItems.length) {",
                  "    pm.collectionVariables.set(\"murtiItemId\", res.data.murtiItems[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Orders",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] }
          }
        },
        {
          "name": "Get Order By Id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/orders/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{orderId}}"] }
          }
        },
        {
          "name": "Get WhatsApp Message",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/orders/{{orderId}}/whatsapp-message", "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{orderId}}", "whatsapp-message"] }
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\",\n  \"notes\": \"Started painting\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/orders/{{orderId}}/status", "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{orderId}}", "status"] }
          }
        },
        {
          "name": "Update Order",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"totalPrice\": 16000,\n  \"advancePaid\": 6000,\n  \"notes\": \"Updated advance amount\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/orders/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{orderId}}"] }
          }
        }
      ]
    },
    {
      "name": "Photos",
      "item": [
        {
          "name": "Upload Murti Photos",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "photos", "type": "file", "src": [] },
                { "key": "photos", "type": "file", "src": [] }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/photos/{{murtiItemId}}", "host": ["{{baseUrl}}"], "path": ["api", "photos", "{{murtiItemId}}"] },
            "description": "Attach up to 5 files under the 'photos' key. Remove the second formdata row if only uploading one file."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const res = pm.response.json();",
                  "  if (res.data && res.data.length) {",
                  "    pm.collectionVariables.set(\"photoId\", res.data[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Murti Photos",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/photos/{{murtiItemId}}", "host": ["{{baseUrl}}"], "path": ["api", "photos", "{{murtiItemId}}"] }
          }
        },
        {
          "name": "Delete Murti Photo",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/photos/{{photoId}}", "host": ["{{baseUrl}}"], "path": ["api", "photos", "{{photoId}}"] }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/dashboard/stats", "host": ["{{baseUrl}}"], "path": ["api", "dashboard", "stats"] }
          }
        }
      ]
    },
    {
      "name": "Test",
      "item": [
        {
          "name": "Upload Test Image",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "image", "type": "file", "src": [] }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/test/upload", "host": ["{{baseUrl}}"], "path": ["api", "test", "upload"] }
          }
        }
      ]
    }
  ]
}
